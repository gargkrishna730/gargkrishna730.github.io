# ──────────────────────────────────────────────
# Krishna Garg — DevOps Portfolio
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Database (local dev only — not needed for GitHub Pages deployment)
DATABASE_URL=file:./db/custom.db

# Resend API Key — for sending contact form emails
# Get one free at: https://resend.com/signup → API Keys → Create
# Store in GitHub Secrets: RESEND_API_KEY
RESEND_API_KEY=re_your_api_key_here

# Contact API URL — set in GitHub Actions Variables as CONTACT_API_URL
# Live Worker: https://kg-portfolio-contact-api.gargkrishna730.workers.dev/contact
NEXT_PUBLIC_CONTACT_API_URL=/api/contact